{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "admin", "user"] },
        "level": { "type": "number" },
        "bio": { "type": "string" }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "WikiPage": {
      "title": "WikiPage",
      "description": "A wiki page about Huang Shifu",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["biography", "music", "album", "timeline", "event"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "lastEditorUid": { "type": "string" },
        "eventDate": { "type": "string", "format": "date", "description": "The date of the event (YYYY-MM-DD)" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "title", "content", "category"]
    },
    "ForumPost": {
      "title": "ForumPost",
      "description": "A post in the community forum",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorUid": { "type": "string" },
        "section": { "type": "string", "enum": ["music", "news", "fanart", "qa"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "authorUid", "section"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a forum post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "parentId": { "type": "string", "description": "ID of the parent comment for nested replies" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "postId", "authorUid", "content"]
    },
    "Gallery": {
      "title": "Gallery",
      "description": "A collection of images (album)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "authorUid": { "type": "string" },
        "images": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "url": { "type": "string" },
              "name": { "type": "string" }
            }
          } 
        },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "authorUid", "images"]
    },
    "ForumSection": {
      "title": "ForumSection",
      "description": "A section in the forum",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["id", "name"]
    },
    "ImageMap": {
      "title": "ImageMap",
      "description": "Mapping of local image IDs to multiple CDN URLs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "localUrl": { "type": "string" },
        "weiboUrl": { "type": "string" },
        "smmsUrl": { "type": "string" },
        "superbedUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "localUrl"]
    },
    "WikiRevision": {
      "title": "WikiRevision",
      "description": "A historical version of a wiki page",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "pageSlug": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "editorUid": { "type": "string" },
        "editorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "pageSlug", "title", "content", "editorUid"]
    },
    "Music": {
      "title": "Music",
      "description": "A song from NetEase Cloud Music",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "album": { "type": "string" },
        "cover": { "type": "string" },
        "audioUrl": { "type": "string" },
        "lyric": { "type": "string" },
        "addedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "artist", "album", "cover", "audioUrl"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/wiki": {
      "schema": "WikiPage",
      "description": "Wiki pages"
    },
    "/wiki/{slug}/revisions": {
      "schema": "WikiRevision",
      "description": "Historical versions of a wiki page"
    },
    "/posts": {
      "schema": "ForumPost",
      "description": "Forum posts"
    },
    "/posts/{postId}/comments": {
      "schema": "Comment",
      "description": "Comments on a post"
    },
    "/galleries": {
      "schema": "Gallery",
      "description": "Image galleries/albums"
    },
    "/sections": {
      "schema": "ForumSection",
      "description": "Forum sections"
    },
    "/imageMaps": {
      "schema": "ImageMap",
      "description": "Image CDN mappings"
    },
    "/music": {
      "schema": "Music",
      "description": "Community curated music list"
    }
  }
}
