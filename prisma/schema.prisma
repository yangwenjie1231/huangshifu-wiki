generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
  super_admin
}

enum UserStatus {
  active
  banned
}

enum ContentStatus {
  draft
  pending
  published
  rejected
}

enum ModerationTargetType {
  wiki
  post
}

enum ModerationAction {
  submit
  approve
  reject
  rollback
}

enum FavoriteTargetType {
  wiki
  post
  music
}

enum UserBanAction {
  ban
  unban
}

enum NotificationType {
  reply
  like
  review_result
}

enum BrowsingTargetType {
  wiki
  post
  music
}

enum UploadSessionStatus {
  open
  finalized
  expired
}

enum MediaAssetStatus {
  uploaded
  ready
  deleted
}

enum EmbeddingStatus {
  pending
  processing
  ready
  failed
}

enum MusicPlatform {
  netease
  tencent
  kugou
  baidu
  kuwo
}

enum DisplayAlbumMode {
  none
  linked
  manual
}

enum MusicCollectionType {
  album
  playlist
}

enum WikiBranchStatus {
  draft
  pending_review
  merged
  rejected
  conflict
}

enum WikiPullRequestStatus {
  open
  merged
  rejected
}

model User {
  uid           String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  displayName   String
  photoURL      String?
  wechatOpenId  String?        @unique
  wechatUnionId String?
  role          UserRole       @default(user)
  status        UserStatus     @default(active)
  banReason     String?
  bannedAt      DateTime?
  level         Int            @default(1)
  bio           String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  posts         Post[]         @relation("UserPosts")
  comments      PostComment[]  @relation("UserComments")
  wikiEdits     WikiPage[]     @relation("WikiLastEditor")
  revisions     WikiRevision[] @relation("WikiRevisionEditor")
  wikiBranches  WikiBranch[]   @relation("WikiBranchEditor")
  wikiPullRequests WikiPullRequest[] @relation("WikiPullRequestCreator")
  wikiReviewedPullRequests WikiPullRequest[] @relation("WikiPullRequestReviewer")
  wikiPullRequestComments WikiPullRequestComment[] @relation("WikiPRCommentAuthor")
  galleries     Gallery[]      @relation("UserGalleries")
  musicAdded    MusicTrack[]   @relation("MusicAddedBy")
  postLikes     PostLike[]
  favorites     Favorite[]
  moderationLogs ModerationLog[] @relation("ModerationOperator")
  userBanOps    UserBanLog[]   @relation("UserBanActionBy")
  userBanTargets UserBanLog[]  @relation("UserBanActionTarget")
  notifications Notification[]
  browsingHistories BrowsingHistory[]
  uploadSessions UploadSession[]
  mediaAssets   MediaAsset[]

  @@index([status, createdAt])
  @@index([wechatUnionId])
}

model Section {
  id          String   @id
  name        String
  description String   @default("")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]

  @@index([createdAt])
}

model Post {
  id            String        @id @default(cuid())
  title         String
  section       String
  content       String
  tags          Json?
  authorUid     String
  status        ContentStatus @default(published)
  reviewNote    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  hotScore      Float         @default(0)
  viewCount     Int           @default(0)
  likesCount    Int           @default(0)
  commentsCount Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sectionRef    Section       @relation(fields: [section], references: [id], onDelete: Restrict)
  author        User          @relation("UserPosts", fields: [authorUid], references: [uid], onDelete: Cascade)
  comments      PostComment[]
  likes         PostLike[]

  @@index([section])
  @@index([status, updatedAt])
  @@index([updatedAt])
  @@index([hotScore, updatedAt])
}

model PostComment {
  id         String   @id @default(cuid())
  postId     String
  authorUid  String
  authorName String
  authorPhoto String?
  content    String
  parentId   String?
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author     User     @relation("UserComments", fields: [authorUid], references: [uid], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([parentId])
}

model WikiPage {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  category      String
  content       String
  tags          Json?
  relations     Json?
  eventDate     String?
  status        ContentStatus  @default(published)
  reviewNote    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  viewCount     Int            @default(0)
  favoritesCount Int           @default(0)
  lastEditorUid String
  lastEditorName String
  mainBranchId  String?
  mergedAt      DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastEditor    User           @relation("WikiLastEditor", fields: [lastEditorUid], references: [uid], onDelete: Cascade)
  revisions     WikiRevision[]
  branches      WikiBranch[]
  pullRequests  WikiPullRequest[]

  @@index([category, updatedAt])
  @@index([status, updatedAt])
  @@index([eventDate])
  @@index([mainBranchId])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userUid   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@unique([postId, userUid])
  @@index([userUid, createdAt])
}

model Favorite {
  id         String             @id @default(cuid())
  userUid    String
  targetType FavoriteTargetType
  targetId   String
  createdAt  DateTime           @default(now())
  user       User               @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@unique([userUid, targetType, targetId])
  @@index([targetType, targetId])
  @@index([userUid, createdAt])
}

model ModerationLog {
  id         String               @id @default(cuid())
  targetType ModerationTargetType
  targetId   String
  action     ModerationAction
  operatorUid String
  note       String?
  createdAt  DateTime             @default(now())
  operator   User                 @relation("ModerationOperator", fields: [operatorUid], references: [uid], onDelete: Cascade)

  @@index([targetType, targetId, createdAt])
  @@index([operatorUid, createdAt])
}

model UserBanLog {
  id         String        @id @default(cuid())
  targetUid  String
  action     UserBanAction
  operatorUid String
  note       String?
  createdAt  DateTime      @default(now())
  target     User          @relation("UserBanActionTarget", fields: [targetUid], references: [uid], onDelete: Cascade)
  operator   User          @relation("UserBanActionBy", fields: [operatorUid], references: [uid], onDelete: Cascade)

  @@index([targetUid, createdAt])
  @@index([operatorUid, createdAt])
}

model WikiRevision {
  id         String   @id @default(cuid())
  pageSlug   String
  branchId   String?
  title      String
  content    String
  slug       String?
  category   String?
  tags       Json?
  relations  Json?
  eventDate  String?
  editorUid  String
  editorName String
  isAutoSave Boolean  @default(false)
  createdAt  DateTime @default(now())
  page       WikiPage @relation(fields: [pageSlug], references: [slug], onDelete: Cascade)
  editor     User     @relation("WikiRevisionEditor", fields: [editorUid], references: [uid], onDelete: Cascade)
  branch     WikiBranch? @relation("WikiBranchRevisions", fields: [branchId], references: [id], onDelete: SetNull)

  @@index([pageSlug, createdAt])
  @@index([branchId, createdAt])
}

model WikiBranch {
  id               String           @id @default(cuid())
  pageSlug         String
  editorUid        String
  editorName       String
  status           WikiBranchStatus @default(draft)
  latestRevisionId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  page             WikiPage         @relation(fields: [pageSlug], references: [slug], onDelete: Cascade)
  editor           User             @relation("WikiBranchEditor", fields: [editorUid], references: [uid], onDelete: Cascade)
  revisions        WikiRevision[]   @relation("WikiBranchRevisions")
  pullRequests     WikiPullRequest[]

  @@unique([pageSlug, editorUid])
  @@index([pageSlug, status])
  @@index([editorUid])
}

model WikiPullRequest {
  id             String                @id @default(cuid())
  branchId       String
  pageSlug       String
  title          String
  description    String?
  status         WikiPullRequestStatus @default(open)
  createdByUid   String
  createdByName  String
  reviewedBy     String?
  reviewedAt     DateTime?
  mergedAt       DateTime?
  baseRevisionId String?
  conflictData   Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  branch         WikiBranch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  page           WikiPage              @relation(fields: [pageSlug], references: [slug], onDelete: Cascade)
  creator        User                  @relation("WikiPullRequestCreator", fields: [createdByUid], references: [uid], onDelete: Cascade)
  reviewer       User?                 @relation("WikiPullRequestReviewer", fields: [reviewedBy], references: [uid], onDelete: SetNull)
  comments       WikiPullRequestComment[]

  @@unique([branchId])
  @@index([status, createdAt])
  @@index([pageSlug, status])
  @@index([createdByUid, createdAt])
}

model WikiPullRequestComment {
  id         String          @id @default(cuid())
  prId       String
  authorUid  String
  authorName String
  content    String
  createdAt  DateTime        @default(now())
  pr         WikiPullRequest @relation(fields: [prId], references: [id], onDelete: Cascade)
  author     User            @relation("WikiPRCommentAuthor", fields: [authorUid], references: [uid], onDelete: Cascade)

  @@index([prId, createdAt])
  @@index([authorUid, createdAt])
}

model Announcement {
  id        String   @id @default(cuid())
  content   String
  link      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, createdAt])
}

model Gallery {
  id         String         @id @default(cuid())
  title      String
  description String
  authorUid  String
  authorName String
  tags       Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  author     User           @relation("UserGalleries", fields: [authorUid], references: [uid], onDelete: Cascade)
  images     GalleryImage[]

  @@index([createdAt])
}

model UploadSession {
  id           String             @id @default(cuid())
  ownerUid     String
  status       UploadSessionStatus @default(open)
  maxFiles     Int                @default(50)
  uploadedFiles Int               @default(0)
  expiresAt    DateTime
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  owner        User               @relation(fields: [ownerUid], references: [uid], onDelete: Cascade)
  assets       MediaAsset[]

  @@index([ownerUid, status, expiresAt])
}

model MediaAsset {
  id         String          @id @default(cuid())
  ownerUid   String
  sessionId  String?
  storageKey String          @unique
  publicUrl  String
  fileName   String
  mimeType   String
  sizeBytes  Int
  status     MediaAssetStatus @default(ready)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  owner      User            @relation(fields: [ownerUid], references: [uid], onDelete: Cascade)
  session    UploadSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  galleryImages GalleryImage[] @relation("GalleryImageAsset")
  songCovers SongCover[]     @relation("SongCoverAsset")
  albumCovers AlbumCover[]   @relation("AlbumCoverAsset")

  @@index([ownerUid, createdAt])
  @@index([sessionId])
}

model GalleryImage {
  id        String   @id @default(cuid())
  galleryId String
  assetId   String?
  url       String
  name      String
  sortOrder Int      @default(0)
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  asset     MediaAsset? @relation("GalleryImageAsset", fields: [assetId], references: [id], onDelete: SetNull)
  embedding ImageEmbedding?

  @@index([galleryId, sortOrder])
  @@index([assetId])
}

model ImageEmbedding {
  id             String          @id @default(cuid())
  galleryImageId String          @unique
  modelName      String          @default("Xenova/clip-vit-base-patch32")
  vectorSize     Int             @default(512)
  status         EmbeddingStatus @default(pending)
  lastError      String?
  embeddedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  galleryImage   GalleryImage    @relation(fields: [galleryImageId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
}

model Album {
  docId              String              @id @default(cuid())
  id                 String              @unique
  resourceType       MusicCollectionType @default(album)
  platform           MusicPlatform
  sourceId           String
  title              String
  artist             String
  cover              String
  description        String?
  platformUrl        String?
  tracks             Json?
  defaultCoverSource String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  covers             AlbumCover[]
  songRelations      SongAlbumRelation[]

  @@unique([platform, sourceId, resourceType])
  @@index([title])
  @@index([artist])
  @@index([createdAt])
}

model MusicTrack {
  docId     String   @id @default(cuid())
  id        String   @unique
  title     String
  artist    String
  album     String   @default("")
  cover     String   @default("")
  audioUrl  String   @default("")
  lyric     String?
  primaryPlatform    MusicPlatform   @default(netease)
  enabledPlatform    MusicPlatform?
  neteaseId          String?
  tencentId          String?
  kugouId            String?
  baiduId            String?
  kuwoId             String?
  displayAlbumMode   DisplayAlbumMode @default(linked)
  manualAlbumName    String?
  defaultCoverSource String?
  addedBy   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  adder     User?    @relation("MusicAddedBy", fields: [addedBy], references: [uid], onDelete: SetNull)
  covers    SongCover[]
  albumRelations SongAlbumRelation[]
  instrumentalLinks   SongInstrumentalRelation[] @relation("SongInstrumentalSource")
  instrumentalForLinks SongInstrumentalRelation[] @relation("SongInstrumentalTarget")

  @@index([primaryPlatform])
  @@index([enabledPlatform])
  @@index([neteaseId])
  @@index([tencentId])
  @@index([kugouId])
  @@index([baiduId])
  @@index([kuwoId])
  @@index([createdAt])
}

model SongCover {
  id         String    @id @default(cuid())
  songDocId  String
  assetId    String?
  storageKey String    @unique
  publicUrl  String
  isDefault  Boolean   @default(false)
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  song       MusicTrack @relation(fields: [songDocId], references: [docId], onDelete: Cascade)
  asset      MediaAsset? @relation("SongCoverAsset", fields: [assetId], references: [id], onDelete: SetNull)

  @@index([songDocId, sortOrder])
  @@index([assetId])
}

model AlbumCover {
  id         String    @id @default(cuid())
  albumDocId String
  assetId    String?
  storageKey String    @unique
  publicUrl  String
  isDefault  Boolean   @default(false)
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  album      Album     @relation(fields: [albumDocId], references: [docId], onDelete: Cascade)
  asset      MediaAsset? @relation("AlbumCoverAsset", fields: [assetId], references: [id], onDelete: SetNull)

  @@index([albumDocId, sortOrder])
  @@index([assetId])
}

model SongAlbumRelation {
  id         String    @id @default(cuid())
  songDocId  String
  albumDocId String
  discNumber Int       @default(1)
  trackOrder Int       @default(0)
  isDisplay  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  song       MusicTrack @relation(fields: [songDocId], references: [docId], onDelete: Cascade)
  album      Album      @relation(fields: [albumDocId], references: [docId], onDelete: Cascade)

  @@unique([songDocId, albumDocId])
  @@index([albumDocId, discNumber, trackOrder])
  @@index([songDocId])
}

model SongInstrumentalRelation {
  id              String    @id @default(cuid())
  songDocId       String
  targetSongDocId String
  createdAt       DateTime  @default(now())
  song            MusicTrack @relation("SongInstrumentalSource", fields: [songDocId], references: [docId], onDelete: Cascade)
  targetSong      MusicTrack @relation("SongInstrumentalTarget", fields: [targetSongDocId], references: [docId], onDelete: Cascade)

  @@unique([songDocId, targetSongDocId])
  @@index([targetSongDocId])
}

model ImageMap {
  id         String   @id
  md5        String   @unique
  localUrl   String
  weiboUrl   String?
  smmsUrl    String?
  superbedUrl String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userUid   String
  type      NotificationType
  payload   Json
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@index([userUid, isRead, createdAt])
  @@index([userUid, createdAt])
}

model BrowsingHistory {
  id         String            @id @default(cuid())
  userUid    String
  targetType BrowsingTargetType
  targetId   String
  createdAt  DateTime          @default(now())
  user       User              @relation(fields: [userUid], references: [uid], onDelete: Cascade)

  @@index([userUid, createdAt])
  @@index([userUid, targetType, createdAt])
  @@index([targetType, targetId, createdAt])
}

model SearchKeyword {
  keyword   String   @id
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([count, updatedAt])
}
