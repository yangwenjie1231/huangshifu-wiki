# ============================================
# 测试数据库配置
# ============================================
# 注意：此文件包含测试数据库配置，请勿用于生产环境
# 测试数据库与开发数据库完全隔离

# 测试数据库连接字符串
# 使用独立的数据库名称：huangshifu_wiki_test
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/huangshifu_wiki_test"

# JWT 密钥（测试环境使用独立密钥）
JWT_SECRET="test_jwt_secret_replace_with_random_string"

# 测试管理员账户
SEED_SUPER_ADMIN_EMAIL="test_admin@example.com"
SEED_SUPER_ADMIN_PASSWORD="test_password_replace_me"
SEED_SUPER_ADMIN_NAME="测试管理员"

# CORS 配置（测试环境）
CORS_ORIGIN="http://localhost:5173"

# 上传会话 TTL（测试环境缩短时间）
UPLOAD_SESSION_TTL_MINUTES="5"

# 上传路径（使用测试专用目录）
UPLOADS_PATH=""

# 数据库备份配置（测试环境）
BACKUP_PASSWORD="test_backup_password"
BACKUP_RETAIN_COUNT="5"

# ============================================
# 向量搜索配置（测试环境）
# ============================================
QDRANT_URL="http://127.0.0.1:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION="hsf_image_embeddings_test"
IMAGE_EMBEDDING_MODEL="Xenova/clip-vit-base-patch32"
IMAGE_EMBEDDING_VECTOR_SIZE="512"
IMAGE_EMBEDDING_BATCH_SIZE="10"
IMAGE_SEARCH_RESULT_LIMIT="24"

# Transformers 模型配置
TRANSFORMERS_CACHE=""
TRANSFORMERS_OFFLINE="false"

# ============================================
# 微信小程序配置（测试环境）
# ============================================
WECHAT_MP_APPID=""
WECHAT_MP_APP_SECRET=""
WECHAT_LOGIN_MOCK="true"

# ============================================
# S3 对象存储配置（测试环境 - 默认禁用）
# ============================================
S3_ENABLED="false"

S3_READ_ACCESS_KEY_ID=""
S3_READ_SECRET_ACCESS_KEY=""

S3_WRITE_ACCESS_KEY_ID=""
S3_WRITE_SECRET_ACCESS_KEY=""

S3_PUBLIC_BUCKET_NAME=""
S3_PUBLIC_BUCKET_REGION="auto"
S3_PUBLIC_BUCKET_PREFIX="test/"

S3_ENDPOINT_URL=""
S3_FORCE_PATH_STYLE="true"
S3_SSL_ENABLED="true"
S3_SIGNATURE_VERSION="v4"

S3_PUBLIC_DOMAIN=""

# ============================================
# 图床配置（测试环境 - 默认禁用）
# ============================================
SUPERBED_API_TOKEN=""

LSKY_BASE_URL=""
LSKY_TOKEN=""
LSKY_TIMEOUT="30000"

# ============================================
# 前端环境变量（测试环境）
# ============================================
VITE_GEMINI_API_KEY=""
VITE_AMAP_JS_API_KEY=""
VITE_AMAP_SECURITY_JS_CODE=""
AMAP_API_KEY=""
VITE_LSKY_BASE_URL=""
