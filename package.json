{
  "name": "huangshifu-wiki",
  "private": true,
  "version": "0.0.0",
  "description": "黄诗扶 Wiki，一个基于 React、Express、Prisma 和 PostgreSQL 的全栈内容社区系统。",
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/yangwenjie1231/huangshifu-wiki.git"
  },
  "bugs": {
    "url": "https://github.com/yangwenjie1231/huangshifu-wiki/issues"
  },
  "homepage": "https://github.com/yangwenjie1231/huangshifu-wiki#readme",
  "keywords": [
    "wiki",
    "react",
    "express",
    "prisma",
    "postgresql",
    "qdrant",
    "vite",
    "typescript"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "verify": "npm run lint && npm run test:unit && npm run test:integration && npm run build",
    "test": "NODE_ENV=test vitest run --reporter=dot --silent=passed-only",
    "test:unit": "NODE_ENV=test vitest run --reporter=dot --silent=passed-only",
    "test:watch": "NODE_ENV=test vitest --reporter=dot --silent=passed-only",
    "test:coverage": "NODE_ENV=test vitest run --coverage --reporter=dot --silent=passed-only",
    "test:integration": "NODE_ENV=test INTEGRATION_TEST_FAST_BCRYPT=1 DOTENV_CONFIG_QUIET=true vitest run --config vitest.integration.config.ts --reporter=dot",
    "test:db:init": "tsx scripts/test-db-init.ts",
    "test:db:cleanup": "tsx scripts/test-db-cleanup.ts",
    "test:db:reset": "tsx scripts/test-db-cleanup.ts --force && tsx scripts/test-db-init.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "embeddings:sync": "tsx scripts/sync-image-embeddings.ts",
    "embeddings:enqueue": "tsx scripts/sync-image-embeddings.ts --enqueue-only",
    "uploads:cleanup": "tsx scripts/cleanup-orphan-uploads.ts",
    "regions:import": "tsx scripts/import-regions.ts",
    "validate:migrations": "tsx scripts/validate-migrations.ts",
    "check:build": "tsx scripts/check-build-size.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@huggingface/transformers": "^3.8.1",
    "@meting/core": "^1.6.1",
    "@prisma/client": "^6.7.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/nodemailer": "^8.0.1",
    "@uiw/react-md-editor": "^4.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "blurhash": "^2.0.5",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "echarts": "^5.5.1",
    "exifreader": "^4.41.0",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-image-crop": "^11.0.10",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "rehype-autolink-headings": "~7.1.0",
    "rehype-prism-plus": "~2.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "~6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^1.3.1",
    "sharp": "^0.34.5",
    "spark-md5": "^3.0.2",
    "tailwind-merge": "^3.5.0",
    "vis-network": "^10.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/spark-md5": "^3.0.5",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.4.21",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prisma": "^6.7.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "terser": "^5.46.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "overrides": {
    "@babel/core": "7.29.7",
    "form-data": "4.0.6",
    "protobufjs": "7.6.3",
    "tar": "7.5.17",
    "@qdrant/js-client-rest": {
      "undici": "6.27.0"
    },
    "cheerio": {
      "undici": "7.28.0"
    },
    "jsdom": {
      "undici": "7.28.0"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
