# Axios 默认超时时间（毫秒），默认 15000 (15秒)
AXIOS_DEFAULT_TIMEOUT="15000"

# Gemini
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Amap (高德地图) - Frontend JS API key
VITE_AMAP_JS_API_KEY="YOUR_AMAP_JS_API_KEY"
# Amap JS API 安全密钥 (必须在 JS API 脚本加载之前设置)
VITE_AMAP_SECURITY_JS_CODE="YOUR_AMAP_SECURITY_JS_CODE"

# Amap (高德地图) - Backend Web Service API key (for server-side geocoding)
AMAP_API_KEY="YOUR_AMAP_WEB_SERVICE_API_KEY"

# Local backend
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/huangshifu_wiki"
JWT_SECRET="replace_with_random_long_secret"

# Admin seed account
SEED_SUPER_ADMIN_EMAIL="admin@example.com"
SEED_SUPER_ADMIN_PASSWORD="replace_with_strong_password"
SEED_SUPER_ADMIN_NAME="诗扶小筑管理员"

# Optional
CORS_ORIGIN=""
UPLOAD_SESSION_TTL_MINUTES="45"

# Custom uploads storage path (absolute path, e.g., /var/www/huangshifu-wiki/uploads)
UPLOADS_PATH=""

# Database backup
BACKUP_PASSWORD="replace_with_backup_password"
BACKUP_RETAIN_COUNT="20"

# Vector search (Qdrant + CLIP)
QDRANT_URL="http://127.0.0.1:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION="hsf_image_embeddings"
# 支持 chinese-clip (如 OFA-Sys/chinese-clip-vit-large-patch14) 或 clip (如 Xenova/clip-vit-base-patch32) 模型
IMAGE_EMBEDDING_MODEL="OFA-Sys/chinese-clip-vit-base-patch16"
# 向量维度: chinese-clip-vit-base-patch16 为 512, 原始 CLIP ViT-B/32 为 512
IMAGE_EMBEDDING_VECTOR_SIZE="512"
IMAGE_EMBEDDING_BATCH_SIZE="100"
# 量化类型: 'q8'(int8量化, 省内存) 或 'fp32'(全精度), 默认 q8
# 当官方无预量化模型时，系统会在首次加载时通过 Python onnxruntime 自动执行动态量化生成 int8 模型。如果 Python/onnxruntime 不可用则自动降级为 fp32。
IMAGE_EMBEDDING_DTYPE="q8"
IMAGE_SEARCH_RESULT_LIMIT="24"

# Transformers 模型配置
# 模型缓存目录，默认为项目根目录下的 models/transformers
TRANSFORMERS_CACHE=""
# 设置为 true 使用离线模式（不下载模型，仅使用本地缓存）
TRANSFORMERS_OFFLINE="false"
# HuggingFace 网络探测超时(毫秒)，默认 5000。设为 0 跳过探测直接尝试 HF
HF_PROBE_TIMEOUT_MS="5000"
# 设置为 true 跳过网络自动探测，始终先尝试 HuggingFace（失败后再 fallback ModelScope）
SKIP_NETWORK_PROBE="false"

# WeChat mini-program auth (P2)
WECHAT_MP_APPID=""
WECHAT_MP_APP_SECRET=""
WECHAT_LOGIN_MOCK="false"

# ============================================
# S3 对象存储配置 - 用于三重存储模式
# ============================================
# 参考文档: https://docs.bitiful.net/

# 是否启用 S3（true/false）
S3_ENABLED="false"

# 读取凭证（用于生成公开访问 URL）
S3_READ_ACCESS_KEY_ID="your_read_only_access_key_id"
S3_READ_SECRET_ACCESS_KEY="your_read_only_secret_access_key"

# 写入凭证（用于上传文件）
S3_WRITE_ACCESS_KEY_ID="your_write_access_key_id"
S3_WRITE_SECRET_ACCESS_KEY="your_write_secret_access_key"

# 公开存储桶配置
S3_PUBLIC_BUCKET_NAME="your-public-bucket"
S3_PUBLIC_BUCKET_REGION="auto"
S3_PUBLIC_BUCKET_PREFIX="public/"

# S3 兼容端点配置
S3_ENDPOINT_URL="https://s3.bitiful.net"
S3_FORCE_PATH_STYLE="true"
S3_SSL_ENABLED="true"
S3_SIGNATURE_VERSION="v4"

# 可选：公开域名（用于生成更简洁的 URL）
S3_PUBLIC_DOMAIN=""

# ============================================
# Superbed 图床配置 - 用于外部图床上传
# ============================================
# 注册地址: https://www.superbed.cn/
# API 文档: https://www.superbed.cn/help

# Superbed API Token (在用户中心获取)
SUPERBED_API_TOKEN=""

# ============================================
# Lsky Pro+ 图床配置 - 用于 LHL 图床系统集成
# ============================================
# API 文档: https://lsky-pro.apifox.cn/

# Lsky Pro+ API 基础地址（后端使用，安全）
LSKY_BASE_URL="https://your-lsky-pro-domain.com"

# Lsky Pro+ 认证 Token（后端使用，安全）
# 在 Lsky Pro+ 后台 → 用户设置 → Tokens → 创建新 Token
# LSKY_TOKEN=""

# 请求超时时间（毫秒），默认 30000
# LSKY_TIMEOUT="30000"

# ============================================
# 前端环境变量（会被打包到前端代码，不要放敏感信息！）
# ============================================
# Lsky Pro+ API 基础地址（前端使用，仅用于公开的 API 地址）
VITE_LSKY_BASE_URL="https://your-lsky-pro-domain.com"

# ============================================
# 图片变体生成器配置 (v2.1)
# ============================================
# 变体生成最大并发数，默认 3
VARIANT_MAX_CONCURRENT="3"

# 单个变体生成任务超时时间（毫秒），默认 30000 (30秒)
VARIANT_TASK_TIMEOUT_MS="30000"

# 任务在队列中最大等待时间（毫秒），默认 300000 (5分钟)
VARIANT_QUEUE_MAX_WAIT_MS="300000"

# Sharp 库最大内存限制（MB），防止 OOM，默认 512
VARIANT_SHARP_MEMORY_LIMIT_MB="512"

# 变体生成失败后最大重试次数，默认 3
VARIANT_MAX_RETRIES="3"

# ============================================
# 云端同步服务配置 (v2.1)
# ============================================
# 云端同步最大并发数，默认 2
CLOUD_SYNC_MAX_CONCURRENT="2"

# 云端同步失败后最大重试次数，默认 3
CLOUD_SYNC_MAX_RETRIES="3"

# Lsky Pro+ 存储策略 ID（可选，留空则使用默认策略）
LSKY_STRATEGY_ID=""

# ============================================
# 磁盘空间监控配置 (v2.1 - 支持后台动态修改)
# ============================================
# 以下为默认值，可通过管理后台 API 动态修改

# 磁盘剩余空间警告阈值（GB），低于此值触发警告，默认 50
DISK_WARNING_THRESHOLD_GB="50"

# 磁盘剩余空间严重警告阈值（GB），低于此值拒绝上传，默认 20
DISK_CRITICAL_THRESHOLD_GB="20"

# 磁盘检查间隔（毫秒），默认 300000 (5分钟)
DISK_CHECK_INTERVAL_MS="300000"

# 单次上传所需最小空闲空间（MB），用于预检，默认 500
UPLOAD_MIN_FREE_SPACE_MB="500"
