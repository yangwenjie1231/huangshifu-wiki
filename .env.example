# Gemini
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Amap (高德地图) - Frontend JS API key
VITE_AMAP_JS_API_KEY="YOUR_AMAP_JS_API_KEY"
# Amap JS API 安全密钥 (必须在 JS API 脚本加载之前设置)
VITE_AMAP_SECURITY_JS_CODE="YOUR_AMAP_SECURITY_JS_CODE"

# Amap (高德地图) - Backend Web Service API key (for server-side geocoding)
AMAP_API_KEY="YOUR_AMAP_WEB_SERVICE_API_KEY"

# Local backend
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/huangshifu_wiki"
JWT_SECRET="replace_with_random_long_secret"

# Admin seed account
SEED_SUPER_ADMIN_EMAIL="admin@example.com"
SEED_SUPER_ADMIN_PASSWORD="replace_with_strong_password"
SEED_SUPER_ADMIN_NAME="诗扶小筑管理员"

# Optional
CORS_ORIGIN=""
UPLOAD_SESSION_TTL_MINUTES="45"

# Custom uploads storage path (absolute path, e.g., /var/www/huangshifu-wiki/uploads)
UPLOADS_PATH=""

# Database backup
BACKUP_PASSWORD="replace_with_backup_password"
BACKUP_RETAIN_COUNT="20"

# Vector search (Qdrant + CLIP)
QDRANT_URL="http://127.0.0.1:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION="hsf_image_embeddings"
IMAGE_EMBEDDING_MODEL="Xenova/clip-vit-base-patch32"
IMAGE_EMBEDDING_VECTOR_SIZE="512"
IMAGE_EMBEDDING_BATCH_SIZE="100"
IMAGE_SEARCH_RESULT_LIMIT="24"

# WeChat mini-program auth (P2)
WECHAT_MP_APPID=""
WECHAT_MP_APP_SECRET=""
WECHAT_LOGIN_MOCK="false"
