# 黄诗扶 Wiki 环境变量示例
#
# 使用方式：
# 1. 复制为 `.env.local`（本地开发）
# 2. 按需填写必填项
# 3. 前端变量以 `VITE_` 开头，会被打包进浏览器端代码，不能放密钥
#
# 标记说明：
# - [必填]：缺失会导致核心功能不可用
# - [推荐]：生产环境建议显式配置
# - [可选]：留空时使用代码默认值
# - [前端暴露]：会进入前端 bundle


# ============================================================
# 1. 核心必填
# ============================================================

# [必填] PostgreSQL 连接串
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/huangshifu_wiki"

# [必填] JWT 签名密钥，至少 32 字符
JWT_SECRET="replace_with_random_long_secret"


# ============================================================
# 2. 管理员种子账号
# ============================================================

# [推荐] 首次初始化数据库时用于创建超级管理员
SEED_SUPER_ADMIN_EMAIL="admin@example.com"
SEED_SUPER_ADMIN_PASSWORD="replace_with_strong_password"
SEED_SUPER_ADMIN_NAME="诗扶小筑管理员"


# ============================================================
# 3. 运行时与服务端行为
# ============================================================

# [可选] 服务监听端口，默认 3003
PORT="3003"

# [可选] 开发环境 Vite HMR 端口，默认 24678
VITE_HMR_PORT="24678"

# [可选] 日志级别，默认 info
LOG_LEVEL="info"

# [可选] Axios 默认超时（毫秒），默认 15000
AXIOS_DEFAULT_TIMEOUT="15000"

# [可选] 数据库连接池上限，默认按 CPU 核数自动计算
DB_CONNECTION_LIMIT=""

# [可选] 数据库连接池等待超时（秒），默认 10
DB_POOL_TIMEOUT=""

# [可选] 编辑锁清理间隔（毫秒），默认 90000
EDIT_LOCK_CLEANUP_INTERVAL_MS="90000"

# [可选] 音乐播放 URL 缓存 TTL（秒），默认 600
MUSIC_PLAY_URL_CACHE_TTL_SECONDS="600"

# [可选] 服务端缓存最大键数量，默认 5000
CACHE_MAX_KEYS="5000"

# [可选] 仅覆盖认证 Cookie(hsf_token) 的 secure 属性
# 注意：XSRF-TOKEN 不读取该变量，仍由 req.secure / x-forwarded-proto 判断
# true: 强制认证 Cookie 使用 secure
# false: 强制认证 Cookie 不使用 secure
# 留空: 由运行环境自动判断
COOKIE_SECURE=""


# ============================================================
# 4. CORS / 本地开发
# ============================================================

# [可选] 显式允许的跨域来源，逗号分隔。生产环境建议配置明确域名
CORS_ORIGIN=""

# [可选] 仅开发环境使用的额外允许来源，逗号分隔
DEV_CORS_ORIGINS=""

# [可选] 仅开发环境生效。true 时禁用全局和领域限流
DEV_DISABLE_RATE_LIMIT="false"

# [可选] Vite HMR 总开关。true 时禁用 HMR
DISABLE_HMR="false"

# [可选] 构建分析开关。true 时输出 bundle 分析
ANALYZE="false"


# ============================================================
# 5. 上传、媒体与备份
# ============================================================

# [可选] 上传根目录，留空时使用项目默认 uploads/
UPLOADS_PATH=""

# [可选] 上传会话有效期（分钟），默认 45
UPLOAD_SESSION_TTL_MINUTES="45"

# [可选] 单次上传所需最小剩余空间（MB），默认 500
UPLOAD_MIN_FREE_SPACE_MB="500"

# [可选] 兼容测试中的旧命名，生产不建议单独设置
UPLOADS_MIN_FREE_SPACE_MB=""

# [推荐] 备份加密密码；启用备份/恢复功能时必须配置
BACKUP_PASSWORD="replace_with_backup_password"

# [可选] 最多保留多少个备份文件，默认 20
BACKUP_RETAIN_COUNT="20"

# [可选] 临时限制图集写操作仅管理员可用，默认 false
GALLERY_ADMIN_ONLY="false"


# ============================================================
# 6. 图片处理
# ============================================================

# [可选] 是否启用 Blurhash，默认 true
BLURHASH_ENABLED="true"

# [可选] 是否自动生成 Blurhash，默认 true
BLURHASH_AUTO_GENERATE="true"

# [可选] Blurhash 横向分量，默认 4
BLURHASH_COMPONENTS_X="4"

# [可选] Blurhash 纵向分量，默认 3
BLURHASH_COMPONENTS_Y="3"


# ============================================================
# 7. 地图与地理位置
# ============================================================

# [可选] 高德服务端 Web Service API Key
AMAP_API_KEY=""

# [前端暴露] [可选] 高德 JS API Key
VITE_AMAP_JS_API_KEY=""

# [前端暴露] [可选] 高德 JS API 安全密钥
VITE_AMAP_SECURITY_JS_CODE=""


# ============================================================
# 8. 向量检索 / CLIP / Qdrant
# ============================================================

# [可选] Qdrant 地址
QDRANT_URL="http://127.0.0.1:6333"

# [可选] Qdrant API Key
QDRANT_API_KEY=""

# [可选] 图片向量集合名
QDRANT_COLLECTION="hsf_image_embeddings"

# [可选] 文本向量集合名
QDRANT_TEXT_COLLECTION="hsf_text_embeddings"

# [可选] 搜索接口里向量检索超时（毫秒），默认 2000
QDRANT_TIMEOUT_MS="2000"

# [可选] 向量模型名
IMAGE_EMBEDDING_MODEL="OFA-Sys/chinese-clip-vit-base-patch16"

# [可选] 向量维度，默认 512
IMAGE_EMBEDDING_VECTOR_SIZE="512"

# [可选] 批量同步时每批大小，默认 100
IMAGE_EMBEDDING_BATCH_SIZE="100"

# [可选] 向量精度 / 量化类型，默认 q8
IMAGE_EMBEDDING_DTYPE="q8"

# [可选] 图片向量搜索默认返回数量，默认 24
IMAGE_SEARCH_RESULT_LIMIT="24"

# [可选] transformers 模型缓存目录，留空时使用 models/transformers
TRANSFORMERS_CACHE=""

# [可选] true 时仅使用本地模型缓存，不访问远端
TRANSFORMERS_OFFLINE="false"

# [可选] Hugging Face 可达性探测超时（毫秒），默认 5000
HF_PROBE_TIMEOUT_MS="5000"

# [可选] true 时跳过 Hugging Face 网络探测
SKIP_NETWORK_PROBE="false"


# ============================================================
# 10. 微信小程序登录
# ============================================================

# [可选] 推荐使用的新命名
WECHAT_MP_APPID=""
WECHAT_MP_APP_SECRET=""

# [可选] 兼容旧命名
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
WECHAT_MP_APPSECRET=""

# [可选] 仅开发环境生效。true 时启用微信登录 mock
WECHAT_LOGIN_MOCK="false"


# ============================================================
# 11. S3 兼容对象存储
# ============================================================

# [可选] 是否启用 S3
S3_ENABLED="false"

# [推荐] 读取凭证，用于生成公开访问 URL
S3_READ_ACCESS_KEY_ID="your_read_only_access_key_id"
S3_READ_SECRET_ACCESS_KEY="your_read_only_secret_access_key"

# [推荐] 写入凭证，用于上传和删除对象
S3_WRITE_ACCESS_KEY_ID="your_write_access_key_id"
S3_WRITE_SECRET_ACCESS_KEY="your_write_secret_access_key"

# [推荐] 公共存储桶配置
S3_PUBLIC_BUCKET_NAME="your-public-bucket"
S3_PUBLIC_BUCKET_REGION="auto"
S3_PUBLIC_BUCKET_PREFIX="public/"

# [可选] 私有存储桶配置（当前服务端未直接使用，但配置常量中已保留）
S3_PRIVATE_BUCKET_NAME=""
S3_PRIVATE_BUCKET_REGION="auto"

# [推荐] S3 兼容端点配置
S3_ENDPOINT_URL="https://s3.bitiful.net"
S3_FORCE_PATH_STYLE="true"
S3_SSL_ENABLED="true"
S3_SIGNATURE_VERSION="v4"

# [可选] 公共访问域名；留空时拼 endpoint/bucket/prefix
S3_PUBLIC_DOMAIN=""

# [可选] 默认 ACL，当前主要作为配置兼容项保留
S3_DEFAULT_ACL="public-read"

# [可选] 预签名 URL 过期时间（秒），默认 3600
S3_EXPIRES_IN="3600"

# [可选] 单文件最大大小（字节），默认 104857600（100MB）
S3_MAX_FILE_SIZE="104857600"

# [可选] 允许的内容类型，逗号分隔
S3_ALLOWED_CONTENT_TYPES="image/jpeg,image/png,image/gif,image/webp,image/bmp"

# [可选] true 时服务端生成上传预签名 URL 必须收到 contentMd5
# contentMd5 必须是 base64 编码的 MD5 摘要，并会被签入 Content-MD5
S3_ENABLE_MD5_VERIFICATION="false"


# ============================================================
# 12. 外部图床
# ============================================================

# [可选] Superbed API Token
SUPERBED_API_TOKEN=""

# [可选] Lsky Pro+ 后端地址
LSKY_BASE_URL="https://your-lsky-pro-domain.com"

# [可选] Lsky Pro+ 后端 Token
LSKY_TOKEN=""

# [可选] Lsky Pro+ 请求超时（毫秒），默认 30000
LSKY_TIMEOUT="30000"

# [可选] Lsky Pro+ 存储策略 ID
LSKY_STRATEGY_ID=""

# [前端暴露] [可选] Lsky Pro+ 公开 API 地址
VITE_LSKY_BASE_URL="https://your-lsky-pro-domain.com"


# ============================================================
# 13. 变体生成、云同步、磁盘监控
# ============================================================

# [可选] 图片变体生成
VARIANT_MAX_CONCURRENT="3"
VARIANT_TASK_TIMEOUT_MS="30000"
VARIANT_QUEUE_MAX_WAIT_MS="300000"
VARIANT_SHARP_MEMORY_LIMIT_MB="512"
VARIANT_MAX_RETRIES="3"

# [可选] 云同步
CLOUD_SYNC_MAX_CONCURRENT="2"
CLOUD_SYNC_MAX_RETRIES="3"

# [可选] 磁盘监控默认值
DISK_WARNING_THRESHOLD_GB="50"
DISK_CRITICAL_THRESHOLD_GB="20"
DISK_CHECK_INTERVAL_MS="300000"


# ============================================================
# 14. 构建 / 工具脚本
# ============================================================

# [可选] 构建产物体积警告阈值（字节），默认 50MB
BUILD_WARN_THRESHOLD="52428800"

# [可选] 构建产物体积错误阈值（字节），默认 100MB
BUILD_ERROR_THRESHOLD="104857600"


# ============================================================
# 15. 其他
# ============================================================

# 生产环境必须由进程管理器、容器或部署平台设置 NODE_ENV=production。
# 不要在示例文件中写 NODE_ENV=""，空值会让 server.ts 进入开发模式。
