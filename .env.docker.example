# 黄诗扶 Wiki Docker 生产环境变量示例
#
# 使用方式：
# 1. 复制为 `.env`
# 2. 修改所有 replace_with_* 占位值
# 3. 执行 `./scripts/deploy-docker.sh`

# ============================================================
# 1. Docker Compose
# ============================================================

APP_PORT="3003"
APP_IMAGE="ghcr.io/yangwenjie1231/huangshifu-wiki:latest"
DEPLOY_IMAGE_MODE="pull"
POSTGRES_USER="hsf_wiki"
POSTGRES_PASSWORD="replace_with_random_postgres_password"
POSTGRES_DB="huangshifu_wiki"

# 可选：国内服务器可改为 https://registry.npmmirror.com
NPM_REGISTRY="https://registry.npmjs.org"


# ============================================================
# 2. 核心必填
# ============================================================

DATABASE_URL="postgresql://hsf_wiki:replace_with_random_postgres_password@postgres:5432/huangshifu_wiki"
JWT_SECRET="replace_with_random_long_secret_at_least_32_chars"


# ============================================================
# 4. 运行时与域名
# ============================================================

NODE_ENV="production"
PORT="3003"
LOG_LEVEL="info"

# 生产环境建议配置为你的 HTTPS 域名，例如 https://wiki.example.com
CORS_ORIGIN=""
COOKIE_SECURE=""

UPLOADS_PATH="/app/uploads"
UPLOAD_SESSION_TTL_MINUTES="45"
UPLOAD_MIN_FREE_SPACE_MB="500"

BACKUP_PASSWORD="replace_with_backup_password"
BACKUP_RETAIN_COUNT="20"
PG_DUMP_PATH=""
PSQL_PATH=""


# ============================================================
# 5. 图片处理
# ============================================================

BLURHASH_ENABLED="true"
BLURHASH_AUTO_GENERATE="true"
BLURHASH_COMPONENTS_X="4"
BLURHASH_COMPONENTS_Y="3"


# ============================================================
# 6. 语义搜索 / Qdrant
# ============================================================

# 快速生产部署默认关闭。需要图片语义搜索时改为 true 后重新部署。
ENABLE_SEMANTIC_SEARCH="false"
QDRANT_URL="http://qdrant:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION="hsf_image_embeddings"
QDRANT_TEXT_COLLECTION="hsf_text_embeddings"
QDRANT_TIMEOUT_MS="2000"

IMAGE_EMBEDDING_MODEL="OFA-Sys/chinese-clip-vit-base-patch16"
IMAGE_EMBEDDING_VECTOR_SIZE="512"
IMAGE_EMBEDDING_BATCH_SIZE="100"
IMAGE_EMBEDDING_DTYPE="q8"
IMAGE_SEARCH_RESULT_LIMIT="24"

TRANSFORMERS_CACHE="/app/models/transformers"
TRANSFORMERS_OFFLINE="false"
HF_PROBE_TIMEOUT_MS="5000"
SKIP_NETWORK_PROBE="false"


# ============================================================
# 7. 地图与微信
# ============================================================

AMAP_API_KEY=""
VITE_AMAP_JS_API_KEY=""
VITE_AMAP_SECURITY_JS_CODE=""

WECHAT_MP_APPID=""
WECHAT_MP_APP_SECRET=""
# Docker 示例面向生产环境，必须保持 false 或留空，否则服务会拒绝启动
WECHAT_LOGIN_MOCK="false"


# ============================================================
# 8. S3 / 外部图床（可选）
# ============================================================

S3_ENABLED="false"
S3_READ_ACCESS_KEY_ID=""
S3_READ_SECRET_ACCESS_KEY=""
S3_WRITE_ACCESS_KEY_ID=""
S3_WRITE_SECRET_ACCESS_KEY=""
S3_PUBLIC_BUCKET_NAME=""
S3_PUBLIC_BUCKET_REGION="auto"
S3_PUBLIC_BUCKET_PREFIX="public/"
S3_ENDPOINT_URL=""
S3_FORCE_PATH_STYLE="true"
S3_SSL_ENABLED="true"
S3_SIGNATURE_VERSION="v4"
S3_PUBLIC_DOMAIN=""

SUPERBED_API_TOKEN=""
LSKY_BASE_URL=""
LSKY_TOKEN=""
LSKY_STRATEGY_ID=""
VITE_LSKY_BASE_URL=""
