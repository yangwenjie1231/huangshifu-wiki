# =============================
# Deployment metadata (shared)
# =============================
# Project absolute path on server
APP_DIR="/root/huangshifu-wiki"
# PM2 process name
APP_NAME="huangshifu-wiki"
# App listen port
APP_PORT="3000"
# External domain (for Nginx + CORS)
APP_DOMAIN="your-domain.com"

# =============================
# Database bootstrap helpers
# =============================
DB_NAME="huangshifu_wiki"
DB_APP_USER="hsf_app"
DB_APP_PASSWORD="replace_with_strong_password"

# =============================
# Runtime required
# =============================
DATABASE_URL="postgresql://hsf_app:replace_with_strong_password@127.0.0.1:5432/huangshifu_wiki"
JWT_SECRET="replace_with_random_long_secret_at_least_32_chars"
SEED_SUPER_ADMIN_EMAIL="admin@example.com"
SEED_SUPER_ADMIN_PASSWORD="replace_with_strong_password"
SEED_SUPER_ADMIN_NAME="诗扶小筑管理员"

# =============================
# Runtime recommended
# =============================
PORT="3000"
CORS_ORIGIN="https://your-domain.com"
COOKIE_SECURE="true"
UPLOAD_SESSION_TTL_MINUTES="45"
EDIT_LOCK_TTL_MINUTES="20"

# =============================
# LLM / Gemini config (frontend build-time)
# =============================
VITE_GEMINI_API_KEY=""
VITE_GEMINI_MODEL="gemini-3-flash-preview"
VITE_GEMINI_API_BASE=""
VITE_GEMINI_MAX_TOKENS="1024"

# =============================
# WeChat mini-program auth
# =============================
WECHAT_MP_APPID=""
WECHAT_MP_APP_SECRET=""
WECHAT_LOGIN_MOCK="false"

# =============================
# Vector search (Qdrant + CLIP)
# =============================
QDRANT_URL="http://127.0.0.1:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION="hsf_image_embeddings"
IMAGE_EMBEDDING_MODEL="Xenova/clip-vit-base-patch32"
IMAGE_EMBEDDING_VECTOR_SIZE="512"
IMAGE_EMBEDDING_BATCH_SIZE="100"
IMAGE_SEARCH_RESULT_LIMIT="24"

# =============================
# deploy.sh optional switches
# =============================
PULL_LATEST="0"
SKIP_SEED="0"
INSTALL_MODE="ci"
ENABLE_VECTOR_SYNC="1"
VECTOR_SYNC_LIMIT="100"
